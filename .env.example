# Public app metadata
PUBLIC_APP_URL=http://localhost:3001
SUPPORT_EMAIL=support@example.com

# Turso lookup logging
TURSO_LOGGING_ENABLED=false
TURSO_DATABASE_URL=libsql://your-db-name.turso.io
TURSO_AUTH_TOKEN=your-turso-auth-token

# Trust and enrichment
TRUST_PROXY_HEADERS=false
GEOIP_DATA_PATH=
ALLOW_INSECURE_IP_API=false
ISP_PROVIDER_BASE_URL=http://ip-api.com
ISP_PROVIDER_TIMEOUT_MS=5000
ISP_PROVIDER_CACHE_TTL_MS=900000

# Website probe policy
WEBSITE_TARGET_ALLOWLIST=
WEBSITE_PROBE_TIMEOUT_MS=8000
WEBSITE_PROBE_MAX_REDIRECTS=5
WEBSITE_PROBE_MAX_HTML_BYTES=524288
WEBSITE_ASSET_TIMEOUT_MS=5000
WEBSITE_ASSET_MAX_BYTES=65536
WEBSITE_TLS_TIMEOUT_MS=5000
WEBSITE_DNS_CACHE_TTL_MS=300000

# Rate limits
RATE_LIMIT_WINDOW_MS=60000
CURRENT_LOOKUP_RATE_LIMIT_MAX=20
TARGET_IP_RATE_LIMIT_MAX=12
TARGET_IP_REPEAT_RATE_LIMIT_MAX=6
TARGET_WEBSITE_RATE_LIMIT_MAX=6
TARGET_WEBSITE_REPEAT_RATE_LIMIT_MAX=3
TARGET_UNKNOWN_RATE_LIMIT_MAX=8
TARGET_UNKNOWN_REPEAT_RATE_LIMIT_MAX=4
SWAGGER_RATE_LIMIT_MAX=30

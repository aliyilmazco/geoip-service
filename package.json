{
  "name": "geoip-service",
  "version": "1.0.0",
  "private": true,
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "predev": "node scripts/dev-preflight.js",
    "dev": "next dev -p 3001",
    "dev:clean": "node scripts/dev-preflight.js && node scripts/clean-next.js && next dev -p 3001",
    "prebuild": "mkdir -p .next/server/data && cp node_modules/geoip-lite/data/*.dat .next/server/data/ || true",
    "build": "next build",
    "postbuild": "mkdir -p .next/server/data && cp node_modules/geoip-lite/data/*.dat .next/server/data/ || true",
    "start": "next start -p 3001",
    "lint": "next lint",
    "test": "node --test --experimental-strip-types --import ./tests/register-alias.mjs tests/*.test.ts",
    "update-geo": "node node_modules/geoip-lite/scripts/update-data.js"
  },
  "dependencies": {
    "@libsql/client": "^0.17.2",
    "axios": "^1.9.0",
    "geoip-lite": "^1.4.10",
    "leaflet": "^1.9.4",
    "next": "15.1.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-react": "^5.22.0",
    "ua-parser-js": "^2.0.3"
  },
  "devDependencies": {
    "@types/geoip-lite": "^1.4.4",
    "@types/leaflet": "^1.9.21",
    "@types/node": "^20",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "@types/swagger-jsdoc": "^6.0.4",
    "@types/swagger-ui-react": "^5.18.0",
    "@types/ua-parser-js": "^0.7.39",
    "eslint": "^8",
    "eslint-config-next": "15.1.0",
    "typescript": "^5"
  }
}
